PORT=4273
APP_PORT=4273
NODE_ENV=production

REQUIRE_AUTH=1
ALLOW_INSECURE_DEV=0
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_TOKEN=replace-with-a-random-admin-token
CREDENTIAL_SECRET=replace-with-a-random-32-byte-or-longer-secret

DATABASE_DRIVER=postgres
POSTGRES_DB=pt_resource_hub
POSTGRES_USER=pt
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_APP_USER=pt_app
POSTGRES_APP_PASSWORD=replace-with-a-strong-app-role-password
DATABASE_URL=postgres://pt_app:replace-with-a-strong-app-role-password@postgres:5432/pt_resource_hub
DATABASE_MIGRATION_URL=postgres://pt:replace-with-a-strong-postgres-password@postgres:5432/pt_resource_hub
DATABASE_SSL=0
REDIS_URL=redis://redis:6379

PUBLIC_APP_URL=https://pt.example.com
TMDB_API_KEY=
EMAIL_PROVIDER=resend
EMAIL_FROM=PT Resource Hub <noreply@example.com>
RESEND_API_KEY=
SMTP_RELAY_URL=
EMAIL_WEBHOOK_URL=
WEBHOOK_URL=
PAYMENT_PROVIDER=manual
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_BUSINESS=
LEMON_API_KEY=
LEMON_WEBHOOK_SECRET=
LEMON_STORE_ID=
LEMON_VARIANT_STARTER=
LEMON_VARIANT_TEAM=
LEMON_VARIANT_BUSINESS=

ENABLE_SCHEDULER=1
SCHEDULER_INTERVAL_MS=900000
WORKER_ID=worker-production
WORKER_INTERVAL_MS=3000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=180
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15
INVITE_TTL_HOURS=72
BACKUP_DIR=storage/backups
PG_BACKUP_DIR=storage/postgres-backups
RESTORE_DATABASE_URL=
RESTORE_SLA_SECONDS=300
BACKUP_ARCHIVE=1
BACKUP_RETENTION_DAYS=30
OBJECT_RETENTION_DAYS=90
BACKUP_MIN_KEEP=3
BACKUP_LIFECYCLE_DRY_RUN=0
OBJECT_STORAGE_PROVIDER=s3
OBJECT_ARCHIVE_DIR=storage/object-archive
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=pt-resource-hub-backups
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=pt-resource-hub/postgres
PAYMENT_CONTRACT_WORKSPACE_ID=default
PAYMENT_CONTRACT_PLAN=team
MONITORING_ALERTS=1
MONITORING_FAIL_ON_ALERT=1
ALERT_MAX_FAILED_TASKS=0
ALERT_MAX_QUEUED_TASKS=100
ALERT_MAX_FAILED_SOURCES=0
ALERT_MAX_BACKUP_AGE_HOURS=24
ALERT_MAX_SYNC_AGE_HOURS=24

APP_IMAGE=ghcr.io/wwujie9/pt:latest
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
